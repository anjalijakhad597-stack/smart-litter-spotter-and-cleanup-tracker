{
  "name": "smart-litter-spotter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Smart Litter Spotter & Community Cleanup Tracker - Detect, Clean, Inspire.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "detector": "cd python_detector && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "vlm": "cd python_vlm && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8001"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "cors": "^2.8.5",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "leaflet": "^1.9.4",
    "mongoose": "^8.8.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
